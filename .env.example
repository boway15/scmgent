DATABASE_URL=postgresql://scm:scm_dev_pass@127.0.0.1:5432/scm_dev
# Windows + Docker：勿用 localhost（易走 IPv6 ::1 导致 CONNECT_TIMEOUT），用 127.0.0.1
# Docker compose 内使用: postgresql://scm:scm_dev_pass@postgres:5432/scm_dev
PORT=3001
# 本地 Docker: true（Hono 托管 dist）；妙搭: false（NestJS 托管 dist/client）
SERVE_STATIC=false
APP_BASE_URL=http://localhost:8080
# 飞书 OAuth 回调，需与飞书开放平台配置一致
FEISHU_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/feishu/callback
DIFY_BASE_URL=http://10.100.1.154/v1  # 预发；本地 Dify 用 http://127.0.0.1:8090/v1
# Phase 2+ Dify：留空则使用本地 FAQ / 本地算法；见 docs/dify/setup-guide.md
DIFY_API_KEY_KNOWLEDGE=
DIFY_API_KEY_REPLENISHMENT=
DIFY_API_KEY_ALERT=
DIFY_API_KEY_CS_REPLY_QUALITY=
DIFY_API_KEY_SALES_FORECAST=
# Workflow / Chat 超时（毫秒），默认 120000
DIFY_WORKFLOW_TIMEOUT_MS=120000
# 销量预测主算法：legacy（默认）| monthly_abcd（Dify 原型月级 ABCD 分模型）
# FORECAST_ALGO_MODE=monthly_abcd
JWT_SECRET=change-me-in-production

# --- 登录策略（pnpm dev 本地开发）---
AUTH_REQUIRE_LOGIN=true
EMAIL_AUTH_ENABLED=true
FEISHU_AUTH_ENABLED=false
# 紧急调试：跳过登录自动 admin（勿用于生产）
# AUTH_BYPASS_LOGIN=true
# 兼容旧变量（等同 AUTH_BYPASS_LOGIN）
# AUTH_DEV_MODE=true

# 超管初始密码（seed 时写入 admin@scm.local）
BOOTSTRAP_ADMIN_PASSWORD=admin123456

ENFORCE_RBAC=true
CRON_SECRET=change-me-cron-secret
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ALERT_CHAT_ID=
# 飞书多维表格同步（见 docs/feishu-bitable-sync.md）
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_SKUS=
FEISHU_BITABLE_TABLE_INVENTORY=
FEISHU_BITABLE_TABLE_SALES=
FEISHU_BITABLE_TABLE_NEWS_INTEL=
# 跨境资讯采集（RSS → PG → 飞书多维表格）
NEWS_INTEL_ENABLED=true
NEWS_INTEL_LOOKBACK_DAYS=7
NEWS_INTEL_MIN_RELEVANCE=40
NEWS_INTEL_AUTO_PUBLISH_THRESHOLD=70
NEWS_INTEL_LLM_ENABLED=true
NEWS_INTEL_MAX_BODY_CHARS=20000
RSSHUB_BASE_URL=
JINA_READER_ENABLED=true
DIFY_API_KEY_NEWS_INTEL=
