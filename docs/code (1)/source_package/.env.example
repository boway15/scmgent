DATABASE_URL=postgresql://scm:scm_dev_pass@localhost:5432/scm_dev
# Docker compose 内使用: postgresql://scm:scm_dev_pass@postgres:5432/scm_dev
PORT=3001
# 本地 Docker: true（Hono 托管 dist）；妙搭: false（NestJS 托管 dist/client）
SERVE_STATIC=false
APP_BASE_URL=http://localhost:8080
# 飞书 OAuth 回调，需与飞书开放平台配置一致
FEISHU_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/feishu/callback
DIFY_BASE_URL=http://localhost:8080/v1
# MVP 不对接 Dify，以下留空即可；Phase 2 启用见 docs/dify-integration-readiness.md
DIFY_API_KEY_KNOWLEDGE=
DIFY_API_KEY_REPLENISHMENT=
DIFY_API_KEY_ALERT=
JWT_SECRET=change-me-in-production
# 本地开发免登录（自动使用 admin@scm.local）；导入妙搭前改为 false 并配置 FEISHU_*
AUTH_DEV_MODE=true
# 开发环境启用菜单级 RBAC（Docker 默认 true）
ENFORCE_RBAC=true
# 自动化任务 API 密钥（Header: X-Cron-Secret）
CRON_SECRET=change-me-cron-secret
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ALERT_CHAT_ID=
